# Veloura Lighting - Environment Configuration

# --- Database & Auth (Supabase) ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Authentication ---
JWT_SECRET=your_luxury_jwt_secret_key
JWT_ALGORITHM=HS256

# --- Service Ports ---
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
PRODUCT_SERVICE_PORT=5002
BOOKING_SERVICE_PORT=5003
PORTFOLIO_SERVICE_PORT=5004
EMAIL_SERVICE_PORT=5005
MANAGEMENT_SERVICE_PORT=6000

# --- Frontend Ports ---
USER_FRONTEND_PORT=3000
ADMIN_FRONTEND_PORT=4000

# --- Third Party Services ---
SENDGRID_API_KEY=your_sendgrid_key_for_notifications

# --- App Settings ---
FLASK_ENV=development
DEBUG=True
